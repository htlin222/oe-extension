{
  "manifest_version": 3,
  "name": "OpenEvidence Selection Opener",
  "version": "0.1.3",
  "description": "Show an OE button after selecting text on whitelisted sites and open the selection in OpenEvidence.",
  "permissions": ["storage", "tabs", "contextMenus"],
  "host_permissions": ["<all_urls>", "https://api.groq.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "OpenEvidence Selection Opener",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
